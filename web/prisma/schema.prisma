generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  icon      String
  color     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  accounts          Account[]
  accountHoldings   AccountHoldings[]
  familyMembers     FamilyMember[]
  financialAccounts FinancialAccount[]
  ownedHousehold    Household?         @relation("HouseholdOwner")
  householdMember   HouseholdMember?
  incomeSources     IncomeSource[]
  monthlySnapshots  MonthlySnapshot[]
  properties        Property[]
  recurringExpenses RecurringExpense[]
  sessions          Session[]
  transactions      Transaction[]
  userData          UserData?
  variableExpenses  VariableExpense[]
}

model UserData {
  id         String   @id @default(cuid())
  userId     String   @unique
  aiInsights Json?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Household {
  id          String            @id @default(cuid())
  ownerId     String            @unique
  inviteToken String?           @unique
  createdAt   DateTime          @default(now())
  owner       User              @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     HouseholdMember[]
}

model Transaction {
  id                 String            @id
  userId             String
  date               String
  merchant           String
  amount             Float
  transactionAmount  Float?
  type               String
  calCategory        String?
  cardLast4          String?
  accountLabel       String?
  notes              String?
  expenseCategory    String?
  recurringExpenseId String?
  overrideAmount     Float?
  mappingStatus      String            @default("unmapped")
  importedAt         DateTime          @default(now())
  month              String
  variableExpenseId  String?
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onUpdate: NoAction)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  variableExpense    VariableExpense?  @relation(fields: [variableExpenseId], references: [id], onUpdate: NoAction)

  @@index([userId, month])
  @@index([userId, mappingStatus])
  @@index([userId, variableExpenseId])
}

model Property {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  address             String?
  lat                 Float?
  lng                 Float?
  propertyType        String   @default("apartment")
  estimatedValue      Float
  valuationDate       String
  description         String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  aiEstimateReasoning String?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FinancialAccount {
  id              String           @id @default(cuid())
  userId          String
  name            String
  type            String
  kind            String           @default("custom")
  owner           String?
  notes           String?
  url             String?
  monthlyDeposit  Float?
  feesFixed       Float?
  feesOnBalance   Float?
  feesOnDeposit   Float?
  description     String?
  bankVendor      String?
  brokerageVendor String?
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  holdings        AccountHoldings?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotEntries SnapshotEntry[]

  @@index([userId])
}

model MonthlySnapshot {
  id        String          @id @default(cuid())
  userId    String
  date      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   SnapshotEntry[]

  @@unique([userId, date])
  @@index([userId])
}

model SnapshotEntry {
  id            String           @id @default(cuid())
  snapshotId    String
  accountId     String
  balance       Float
  subBalances   Json?
  lastUpdatedAt DateTime?
  account       FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  snapshot      MonthlySnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, accountId])
}

model FamilyMember {
  id      String  @id @default(cuid())
  userId  String
  name    String
  isChild Boolean @default(false)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model RecurringExpense {
  id           String        @id
  userId       String
  name         String
  amount       Float
  category     String
  billingCycle String
  owner        String?
  notes        String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model VariableExpense {
  id           String        @id
  userId       String
  name         String
  category     String
  owner        String?
  active       Boolean       @default(true)
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IncomeSource {
  id           String   @id
  userId       String
  name         String
  type         String   @default("salary")
  grossAmount  Float
  netAmount    Float
  billingCycle String
  owner        String?
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccountHoldings {
  id            String           @id @default(cuid())
  accountId     String           @unique
  userId        String
  updatedAt     DateTime
  totalValueNIS Float
  holdings      Json
  account       FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HouseholdMember {
  id          String    @id @default(cuid())
  householdId String
  userId      String    @unique
  joinedAt    DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
