# ─── Database ────────────────────────────────────────────────────────────────
# Primary connection string (used by Prisma Client at runtime)
DATABASE_URL="postgresql://user:password@host:5432/finance_hub?sslmode=require"
# Direct connection string (used by prisma db push / migrations — same value as DATABASE_URL for most providers)
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/finance_hub?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# The canonical URL of your deployment (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
